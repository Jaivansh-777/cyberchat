generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  clerkId     String   @unique
  cyberId     String   @unique
  username    String   @default("")
  displayName String   @default("")
  avatarUrl   String?
  email       String   @default("")
  phone       String?
  bio         String?
  lastSeen    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sentRequests     FriendRequest[] @relation("SentRequests")
  receivedRequests FriendRequest[] @relation("ReceivedRequests")
  friendships      Friendship[]    @relation("UserFriends")
  friendOf         Friendship[]    @relation("FriendOf")
  blockers         BlockedUser[]   @relation("Blocker")
  blocked          BlockedUser[]   @relation("Blocked")
  groupMemberships GroupMember[]

  @@map("users")
}

model FriendRequest {
  id        String   @id @default(cuid())
  senderId  String
  receiverId String
  status    String   @default("pending") // pending | accepted | declined
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sender   User @relation("SentRequests", fields: [senderId], references: [clerkId])
  receiver User @relation("ReceivedRequests", fields: [receiverId], references: [clerkId])

  @@unique([senderId, receiverId])
  @@map("friend_requests")
}

model Friendship {
  id        String   @id @default(cuid())
  userClerkId String
  friendClerkId String
  createdAt DateTime @default(now())

  user   User @relation("UserFriends", fields: [userClerkId], references: [clerkId])
  friend User @relation("FriendOf", fields: [friendClerkId], references: [clerkId])

  @@unique([userClerkId, friendClerkId])
  @@map("friendships")
}

model MediaFile {
  id             String   @id @default(cuid())
  userId         String
  clerkId        String
  driveFileId    String   @unique
  fileName       String
  mimeType       String
  size           Int
  webViewLink    String?
  webContentLink String?
  folder         String   @default("users")
  messageId      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("media_files")
}

model BlockedUser {
  id          String   @id @default(cuid())
  blockerClerkId String
  blockedClerkId  String
  createdAt   DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerClerkId], references: [clerkId])
  blocked User @relation("Blocked", fields: [blockedClerkId], references: [clerkId])

  @@unique([blockerClerkId, blockedClerkId])
  @@map("blocked_users")
}

model Group {
  id         String   @id @default(cuid())
  name       String
  description String  @default("")
  avatarUrl  String?
  inviteCode String   @unique @default(cuid())
  createdBy  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  members GroupMember[]
  streamChannelId String @default("")

  @@map("groups")
}

model GroupMember {
  id        String   @id @default(cuid())
  groupId   String
  clerkId   String
  role      String   @default("member")
  joinedAt  DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user   User  @relation(fields: [clerkId], references: [clerkId])

  @@unique([groupId, clerkId])
  @@map("group_members")
}

model CallLog {
  id            String   @id @default(cuid())
  callerId      String
  receiverId    String
  callType      String   // "audio" | "video"
  status        String   // "missed" | "completed" | "cancelled"
  startedAt     DateTime @default(now())
  endedAt       DateTime?
  duration      Int?     // seconds

  @@map("call_logs")
}
